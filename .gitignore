venv/
packages/**/.venv/
*.egg-info/
dist/
build/
# Django
*.log
db.sqlite3
media/
staticfiles/
# Environment
.env
.env.local
.env.prod

# Secrets (ADR-045) — NEVER commit plaintext
secrets.env
!secrets.enc.env
.Kopie*
*.env.bak*
.db_backups/
# IDE
.idea/
.vscode/
*.swp
# OS
.DS_Store
Thumbs.db
# Large files
*.sqlite3
*.log
output_batch/
app_backup/
docs_legacy/
# Sphinx / docs build output (any depth)
**/_build/

# WSL Zone.Identifier metadata (all variants)
*Zone.Identifier
*:Zone.Identifier
# Local Windsurf/MCP config — machine-specific, never commit
.windsurf/mcp_config.json
# Local infra plaintext secrets — NEVER commit
infra/*.env
infra/*.key
# Validate-ports CI draft (not yet integrated)
.github/workflows/validate-ports.yml
# Markdownlint local config override
.markdownlint.json
# Concept review drafts (local working copies, not for VCS)
docs/concepts/REVIEW-*
# Root-level concepts/ — local build artefacts (adr-actions, pptx-hub, ...),
# untracked scratch space, never meant for VCS (ARCH-7, #1202). NOT the same
# as the tracked docs/concepts/ above — root anchor keeps this scoped.
/concepts/
env_loader.py
.pat
.env.backup

# PDF-Dateien (generiert via print_agent)
*.pdf
!docs/pdf/*.pdf

# Auto-generierter Editor-Cache (claude-next-sync) — analog dev-hub
NEXT.md

# worktree-reaper.py Lauf-Protokoll (lokales Artefakt, kein VCS)
worktree-reaper-manifest.jsonl
