# BF Agent Environment Configuration
# Copy this file to .env and fill in your values

# Django Settings
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (SQLite is default, uncomment for PostgreSQL)
# DATABASE_URL=postgresql://user:password@localhost:5432/bfagent

# LLM Configuration
# Choose your LLM provider by setting ONE of these API keys:

# Option 1: OpenAI (GPT-4, GPT-3.5-turbo, etc.)
OPENAI_API_KEY=sk-your-openai-api-key-here

# Option 2: Anthropic (Claude 3 Opus, Sonnet, Haiku)
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# LLM Provider Selection (optional, defaults to 'openai')
# LLM_PROVIDER=openai
# LLM_PROVIDER=anthropic

# LLM Model Selection (optional, uses provider defaults if not set)
# For OpenAI:
# LLM_MODEL=gpt-4
# LLM_MODEL=gpt-4-turbo
# LLM_MODEL=gpt-3.5-turbo

# For Anthropic:
# LLM_MODEL=claude-3-opus-20240229
# LLM_MODEL=claude-3-sonnet-20240229
# LLM_MODEL=claude-3-haiku-20240307

# Email Configuration (for production)
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-email@example.com
# EMAIL_HOST_PASSWORD=your-email-password

# Logging Level
# LOG_LEVEL=INFO

# =============================================================================
# SENTRY INTEGRATION (Error Tracking & AI Analysis)
# =============================================================================
# Get your DSN from: https://sentry.io/settings/projects/
# Free tier: 5,000 events/month
SENTRY_DSN=

# Environment name (development, staging, production)
SENTRY_ENVIRONMENT=development

# Optional: Release version for tracking
# SENTRY_RELEASE=1.0.0

# Performance monitoring (1.0 = 100% of transactions)
SENTRY_TRACES_SAMPLE_RATE=1.0
SENTRY_PROFILES_SAMPLE_RATE=1.0

# =============================================================================
# GRAFANA INTEGRATION (Monitoring & Observability)
# =============================================================================
# For Grafana Cloud (free tier: 10k metrics, 50GB logs)
# Sign up at: https://grafana.com/auth/sign-up/create-user
GRAFANA_URL=
# Example: https://YOUR_ORG.grafana.net

# Service Account Token (create in Grafana UI)
# Administration → Service Accounts → Add service account
GRAFANA_TOKEN=

# Optional: Organization ID
# GRAFANA_ORG_ID=
