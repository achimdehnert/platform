[flake8]
max-line-length = 100
extend-ignore =
    E203,
    E501,
    W503,
    F541,
    E731,

exclude =
    .git,
    __pycache__,
    .venv,
    venv,
    .tox,
    dist,
    build,
    *.egg,
    migrations,
    staticfiles,
    media,
    node_modules,
    .pytest_cache,
    htmlcov,

per-file-ignores =
    __init__.py: F401
    settings/*.py: F401,F403,F405
    tests/*.py: F401,F811
    scripts/*.py: E501,F401,E402,F841,E722
    # Deprecated files - ignore complexity and Django warnings
    apps/bfagent/services/book_export.py: C901,DJ01
    apps/bfagent/services/content_storage.py: C901,DJ01
    # Models - DJ01 is intentional for nullable text fields in some cases
    apps/bfagent/models_main.py: DJ01
    # Code backups - ignore all
    .code_backups/*.py: E501,F401,E402,B001,C901
    .tool_backups/*.py: E501,F401,E402,B001,C901

# Django specific
django-settings-module = config.settings

# Max complexity (raised for existing complex functions)
max-complexity = 15
