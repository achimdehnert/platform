{
  "project": {
    "name": "Django Professional Project",
    "description": "Professional Django Web Application with SQLite Database Integration",
    "version": "1.0.0",
    "type": "django-web-application"
  },
  "windsurf": {
    "serve": {
      "enabled": true,
      "port": 8000,
      "host": "localhost",
      "auto_reload": true,
      "interface": "web"
    },
    "memory_bank": {
      "enabled": true,
      "storage_path": "./memory-bank",
      "context_sharing": true,
      "persistent_sessions": true,
      "max_context_size": 50000
    },
    "django_integration": {
      "frameworks": ["django", "djangorestframework"],
      "context_aware": true,
      "database_integration": true,
      "admin_interface": true
    }
  },
  "development": {
    "hot_reload": true,
    "debug_mode": true,
    "logging_level": "INFO",
    "auto_save": true,
    "database_backup": true
  },
  "django_project": {
    "apps_dir": "./apps",
    "static_dir": "./static",
    "media_dir": "./media",
    "templates_dir": "./templates",
    "database": "./db.sqlite3"
  }
}
