FROM python:3.11-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PYTHONUTF8=1

WORKDIR /app

RUN pip install --no-cache-dir fastapi==0.115.6 uvicorn==0.30.6 psycopg2-binary==2.9.10 pydantic==2.10.4

COPY mcphub_api/ /app/mcphub_api/

EXPOSE 8080

CMD ["uvicorn", "mcphub_api.app:app", "--host", "0.0.0.0", "--port", "8080"]
