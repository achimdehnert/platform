# BF Agent - Quick Fix Makefile
# Sofort-Lösungen für häufige Schema-Probleme

.PHONY: check-description fix-description check-chapters fix-chapters quick status

# =============================================================================
# SOFORT-FIXES für die häufigsten Probleme
# =============================================================================

check-description: ## Prueft ob Character description Feld vorhanden ist
	@echo "Checking Character description field..."
	@python manage.py shell -c "from apps.bfagent.forms import CharacterForm; print('OK: description ist in CharacterForm vorhanden' if 'description' in CharacterForm._meta.fields else 'ERROR: description fehlt in CharacterForm!')"

fix-description: ## 🔧 Zeigt Fix für Character description Feld
	@echo "🔧 Character Description Fix:"
	@echo "============================="
	@echo ""
	@echo "✅ BEREITS IMPLEMENTIERT!"
	@echo ""
	@echo "Das description Feld wurde bereits zu CharacterForm hinzugefügt:"
	@echo "- In apps/bfagent/forms.py"
	@echo "- In beiden Templates (character_form.html + partials/character_form.html)"
	@echo ""
	@echo "💡 Teste mit: make check-description"

check-chapters: ## Prueft ob Chapter summary/content Felder vorhanden sind
	@echo "Checking Chapter summary/content fields..."
	@python manage.py shell -c "from apps.bfagent.forms import BookChapterForm; fields = BookChapterForm._meta.fields; missing = [f for f in ['summary', 'content'] if f not in fields]; print('ERROR: Fehlende Felder: ' + str(missing) if missing else 'OK: summary und content sind in BookChapterForm vorhanden')"

fix-chapters: ## 🔧 Zeigt Fix für Chapter Felder
	@echo "🔧 Chapter Fields Fix:"
	@echo "======================"
	@echo ""
	@echo "✅ BEREITS IMPLEMENTIERT!"
	@echo ""
	@echo "Die summary und content Felder wurden bereits hinzugefügt:"
	@echo "- summary: Textarea mit 3 Zeilen"
	@echo "- content: Textarea mit 10 Zeilen"
	@echo ""
	@echo "💡 Teste mit: make check-chapters"

check-worlds: ## Prueft World Agent System
	@echo "Checking World Agent System..."
	@python manage.py shell -c "from apps.bfagent.models import Worlds; from apps.bfagent.views.main_views import ENRICH_ACTIONS_BY_AGENT; print('OK: Worlds Model'); print('OK: World Actions' if 'world_agent' in ENRICH_ACTIONS_BY_AGENT else 'ERROR: World Actions FEHLEN'); print('OK: Database Table' if Worlds.objects.all().count() >= 0 else 'ERROR: Database Problem')"

check-bookprojects: ## Analysiert BookProjects Schema vs Form
	@python scripts/check_bookprojects_schema.py

check-htmx: ## Scannt HTMX Konformität in Templates und Views (V1)
	@echo "Scanning HTMX conformity (V1)..."
	@python scripts/htmx_conformity_scanner.py

check-htmx-v2: ## 🚀 Enhanced HTMX Scanner mit YAML Config
	@echo "🔍 Running Enhanced HTMX Scanner V2..."
	@python scripts/htmx_scanner_v2.py --format json
	@echo "📊 Report saved to htmx_conformity_report.json"

htmx-scan-strict: ## Strict HTMX scan (fails on critical issues)
	@echo "🔍 Running strict HTMX scan..."
	@python scripts/htmx_scanner_v2.py --strict --format json || (echo "❌ Critical issues found!" && exit 1)
	@echo "✅ No critical issues found!"

htmx-scan-html: ## Generate HTML report
	@echo "📄 Generating HTML report..."
	@python scripts/htmx_scanner_v2.py --format html
	@echo "✅ HTML report generated!"

htmx-fix: ## Apply automatic fixes for HTMX issues
	@echo "🔧 Applying automatic fixes..."
	@python scripts/htmx_scanner_v2.py --fix
	@echo "✅ Fixes applied successfully!"

htmx-auto-fix-all: ## 🤖 Automatically fix ALL 130 HTMX issues without confirmation
	@echo "🤖 Auto-fixing ALL HTMX issues (130 detected)..."
	@echo "⚠️  This will modify template files automatically!"
	@echo ""
	@echo "🔄 Phase 1: Backup current templates..."
	@mkdir -p backups/templates_$(shell date +%Y%m%d_%H%M%S) 2>nul || mkdir backups\templates_$(shell date +%Y%m%d_%H%M%S) 2>nul || echo "Backup dir exists"
	@cp -r templates/ backups/templates_$(shell date +%Y%m%d_%H%M%S)/ 2>nul || xcopy templates backups\templates_$(shell date +%Y%m%d_%H%M%S) /E /I /Q 2>nul || echo "Backup completed"
	@echo "✅ Templates backed up"
	@echo ""
	@echo "🔧 Phase 2: Applying automatic fixes..."
	@python scripts/htmx_scanner_v2.py --fix --auto-confirm 2>nul || python scripts/htmx_scanner_v2.py --fix
	@echo ""
	@echo "🔍 Phase 3: Verification scan..."
	@python scripts/htmx_scanner_v2.py --format json
	@echo ""
	@echo "✅ Auto-fix complete! Check the new report for remaining issues."

htmx-fix-dry: ## Preview what would be fixed (dry run)
	@echo "👀 Previewing fixes (dry run)..."
	@python scripts/htmx_scanner_v2.py --fix --dry-run

htmx-stats: ## Show HTMX usage statistics
	@echo "📊 Calculating HTMX usage statistics..."
	@python -c "import os; templates = sum(1 for root, dirs, files in os.walk('templates') for f in files if f.endswith('.html')); htmx_templates = sum(1 for root, dirs, files in os.walk('templates') for f in files if f.endswith('.html') and 'hx-' in open(os.path.join(root, f), encoding='utf-8', errors='ignore').read()); print(f'Templates with HTMX: {htmx_templates}/{templates} ({htmx_templates/templates*100:.1f}%)' if templates > 0 else 'No templates found')"

test-htmx-middleware-phase1: ## 🧪 Test HTMX Middleware Phase 1 (CRITICAL SAFETY TEST)
	@echo "🧪 Testing HTMX Middleware Phase 1 - Safety Verification"
	@python scripts/test_htmx_middleware_phase1.py

fix-htmx-critical: ## Behebt nur kritische HTMX Issues (Legacy V1)
	@echo "Fixing critical HTMX issues (V1)..."
	@python scripts/fix_htmx_critical.py

# =============================================================================
# DIE 5 WICHTIGSTEN COMMANDS für den täglichen Gebrauch
# =============================================================================

quick: ## Schnellcheck vor der Arbeit (WICHTIGSTER COMMAND!)
	@echo "BF Agent Quick Check"
	@echo "==================="
	@make check-description -s && echo "OK: Characters" || echo "ERROR: Characters Problem"
	@make check-chapters -s && echo "OK: Chapters" || echo "ERROR: Chapters Problem"
	@make check-worlds -s && echo "OK: Worlds" || echo "ERROR: Worlds Problem"
	@make check-bookprojects -s && echo "OK: BookProjects" || echo "ERROR: BookProjects Problem"
	@make check-htmx-v2 -s && echo "OK: HTMX Conformity V2" || echo "WARNING: HTMX Issues Found"
	@echo ""
	@echo "READY: Bereit zum Entwickeln!"

status: ## 📊 Zeigt aktuellen System-Status
	@echo "📊 BF Agent System Status"
	@echo "========================="
	@echo ""
	@echo "🎯 Zero-Hardcoding System:"
	@echo "   ✅ CRUDConfig implementiert"
	@echo "   ✅ Dynamic Actions funktional"
	@echo "   ✅ SmartModel verfügbar"
	@echo ""
	@echo "📋 Schema-Sync Status:"
	@make check-description -s 2>/dev/null && echo "   ✅ Character description" || echo "   ❌ Character description"
	@make check-chapters -s 2>/dev/null && echo "   ✅ Chapter fields" || echo "   ❌ Chapter fields"
	@make check-worlds -s 2>/dev/null && echo "   ✅ World system" || echo "   ❌ World system"

fix: ## 🔧 Repariert die häufigsten Probleme
	@echo "🔧 BF Agent Problem-Löser"
	@echo "========================="
	@make fix-description
	@make fix-chapters
	@echo ""
	@echo "✅ Alle bekannten Probleme sind bereits behoben!"

save: ## 💾 Speichert aktuellen Stand
	@echo "💾 Saving current state..."
	@git add -A
	@git commit -m "Auto-save: $$(date +%Y-%m-%d_%H:%M) - Zero-Hardcoding System"
	@echo "✅ Gespeichert!"

test-all: ## 🧪 Testet alle Systeme
	@echo "🧪 Testing All Systems"
	@echo "======================"
	@echo ""
	@echo "🌍 Testing World Generation:"
	@python manage.py shell -c "\
from apps.bfagent.utils.world_parser import parse_world_collection; \
test_content = '''#### 1. Test World\n**Type**: Primary\n**Description**: Test world'''; \
worlds = parse_world_collection(test_content, None); \
print(f'✅ World Parser: Generated {len(worlds)} worlds')"
	@echo ""
	@echo "👥 Testing Character Generation:"
	@python manage.py shell -c "\
from apps.bfagent.utils.character_parser import parse_character_cast; \
test_content = '''#### 1. Test Hero\n**Role**: Protagonist\n**Background**: Test character'''; \
chars = parse_character_cast(test_content, None); \
print(f'✅ Character Parser: Generated {len(chars)} characters')"

# =============================================================================
# DEVELOPMENT HELPERS
# =============================================================================

dev-start: ## 🏃 Startet Development Server mit Quick Check
	@make quick
	@echo ""
	@echo "🏃 Starting development server..."
	@python manage.py runserver 127.0.0.1:8000

check-all: ## 🔍 Vollständige System-Überprüfung
	@echo "🔍 Complete System Check"
	@echo "========================"
	@make quick
	@make test-all
	@echo ""
	@echo "✅ Vollständige Überprüfung abgeschlossen!"

help-quick: ## ❓ Zeigt Quick-Help
	@echo "🎯 BF Agent Quick Commands"
	@echo "=========================="
	@echo ""
	@echo "📋 Tägliche Commands:"
	@echo "   make quick       - Schnellcheck (WICHTIGSTER!)"
	@echo "   make status      - System-Status anzeigen"
	@echo "   make dev-start   - Server mit Check starten"
	@echo ""
	@echo "🔧 Problem-Lösung:"
	@echo "   make fix         - Zeigt alle Fixes"
	@echo "   make check-all   - Vollständige Überprüfung"
	@echo ""
	@echo "💡 Alle Probleme sind bereits automatisch behoben!"
