@require_http_methods(["POST"])  # HTMX live test endpoint (REAL CALL)
def agent_test(request: HttpRequest, pk: int) -> HttpResponse:
    """Live-test an agent's assigned LLM using the services.llm_client."""
    agent = get_object_or_404(Agents, pk=pk)
    prompt: str = request.POST.get("prompt", "").strip()
    response_format = (request.POST.get("format") or "").lower()  # "text"|"json"

    if not prompt:
        return render(
            request,
            "bfagent/partials/agent_llm_test_result.html",
            {"agent": agent, "prompt": prompt, "error": "Please enter a prompt to run a test."},
        )
    if not agent.llm_model_id:
        return render(
            request,
            "bfagent/partials/agent_llm_test_result.html",
            {
                "agent": agent,
                "prompt": prompt,
                "error": "No LLM is assigned to this agent. Please set `llm_model_id`.",
            },
        )

    llm = get_object_or_404(Llms, pk=agent.llm_model_id)
    if not llm.is_active:
        return render(
            request,
            "bfagent/partials/agent_llm_test_result.html",
            {
                "agent": agent,
                "prompt": prompt,
                "error": "Assigned LLM is not active. Please activate it first.",
            },
        )

    req = LlmRequest(
        provider=llm.provider or "",
        api_endpoint=llm.api_endpoint or "",
        api_key=llm.api_key or "",
        model=llm.llm_name,
        system=agent.system_prompt or "",
        prompt=prompt,
        temperature=float(llm.temperature or 0.7),
        top_p=float(llm.top_p or 1.0),
        max_tokens=int(llm.max_tokens or 512),
        response_format=response_format,
    )
    result = generate_text(req)
    if not result.get("ok"):
        return render(
            request,
            "bfagent/partials/agent_llm_test_result.html",
            {"agent": agent, "prompt": prompt, "error": result.get("error") or "Unknown error"},
        )
    return render(
        request,
        "bfagent/partials/agent_llm_test_result.html",
        {
            "agent": agent,
            "prompt": prompt,
            "result": result.get("text"),
            "latency_ms": result.get("latency_ms"),
        },
    )


@require_http_methods(["POST"])  # LLM direct test (REAL CALL)
def llm_test(request: HttpRequest, pk: int) -> HttpResponse:
    """Test an LLM configuration directly using the services.llm_client."""
    llm = get_object_or_404(Llms, pk=pk)
    prompt: str = request.POST.get("prompt", "").strip()
    system: str = request.POST.get("system", "").strip()
    response_format = (request.POST.get("format") or "").lower()

    if not prompt:
        return render(
            request,
            "bfagent/partials/llm_test_result.html",
            {
                "llm": llm,
                "prompt": prompt,
                "system": system,
                "error": "Please enter a prompt to run a test.",
            },
        )
    if not llm.is_active:
        return render(
            request,
            "bfagent/partials/llm_test_result.html",
            {
                "llm": llm,
                "prompt": prompt,
                "system": system,
                "error": "This LLM is inactive. Please activate it first.",
            },
        )

    req = LlmRequest(
        provider=llm.provider or "",
        api_endpoint=llm.api_endpoint or "",
        api_key=llm.api_key or "",
        model=llm.llm_name,
        system=system,
        prompt=prompt,
        temperature=float(llm.temperature or 0.7),
        top_p=float(llm.top_p or 1.0),
        max_tokens=int(llm.max_tokens or 512),
        response_format=response_format,
    )
    result = generate_text(req)
    if not result.get("ok"):
        return render(
            request,
            "bfagent/partials/llm_test_result.html",
            {
                "llm": llm,
                "prompt": prompt,
                "system": system,
                "error": result.get("error") or "Unknown error",
            },
        )
    return render(
        request,
        "bfagent/partials/llm_test_result.html",
        {
            "llm": llm,
            "prompt": prompt,
            "system": system,
            "result": result.get("text"),
            "latency_ms": result.get("latency_ms"),
        },
    )


