# LLM CRUD VIEWS
def llm_create(request):
    """Create a new LLM configuration"""
    if request.method == "POST":
        form = LlmForm(request.POST)
        if form.is_valid():
            llm = form.save()
            messages.success(request, f'LLM "{llm.name}" created successfully!')
            if request.htmx:
                # Return updated list with paginator as expected by the partial
                llms_qs = Llms.objects.all().order_by("provider", "name")
                paginator = Paginator(llms_qs, 12)
                page_obj = paginator.get_page(1)
                return render(request, "bfagent/partials/llm_list.html", {"page_obj": page_obj})
            return redirect("bfagent:llm-list")
        else:
            # Invalid POST: return form with 422 for HTMX error routing
            form.add_error(
                None, "Please correct the highlighted errors to save the LLM configuration."
            )
            template = "bfagent/partials/llm_form.html" if request.htmx else "bfagent/llm_form.html"
            context = {"form": form, "title": "Create New LLM"}
            response = render(request, template, context)
            if request.htmx:
                response.status_code = 422
            return response
    else:
        form = LlmForm()

    context = {"form": form, "title": "Create New LLM"}
    template = "bfagent/partials/llm_form.html" if request.htmx else "bfagent/llm_form.html"
    return render(request, template, context)


def llm_edit(request, pk):
    """Edit an existing LLM configuration"""
    llm = get_object_or_404(Llms, pk=pk)

    if request.method == "POST":
        form = LlmForm(request.POST, instance=llm)
        if form.is_valid():
            llm = form.save()
            messages.success(request, f'LLM "{llm.name}" updated successfully!')
            if request.htmx:
                llms_qs = Llms.objects.all().order_by("provider", "name")
                paginator = Paginator(llms_qs, 12)
                page_obj = paginator.get_page(1)
                return render(request, "bfagent/partials/llm_list.html", {"page_obj": page_obj})
            return redirect("bfagent:llm-list")
        else:
            # Help user see there are validation issues
            form.add_error(
                None, "Please correct the highlighted errors to save the LLM configuration."
            )
            template = "bfagent/partials/llm_form.html" if request.htmx else "bfagent/llm_form.html"
            context = {"form": form, "llm": llm, "title": f"Edit {llm.name}"}
            response = render(request, template, context)
            if request.htmx:
                response.status_code = 422
            return response
    else:
        form = LlmForm(instance=llm)

    from django.urls import reverse

    context = {
        "form": form,
        "llm": llm,
        "title": f"Edit {llm.name}",
        "llm_test_url": reverse("bfagent:llm-test", args=[llm.pk]),
    }
    template = "bfagent/partials/llm_form.html" if request.htmx else "bfagent/llm_form.html"
    return render(request, template, context)


def llm_delete(request, pk):
    """Delete an LLM configuration"""
    llm = get_object_or_404(Llms, pk=pk)

    if request.method == "POST":
        llm_name = llm.name
        llm.delete()
        messages.success(request, f'LLM "{llm_name}" deleted successfully!')
        return redirect("bfagent:llm-list")

    context = {"object": llm, "object_type": "LLM"}
    template = (
        "bfagent/partials/confirm_delete.html" if request.htmx else "bfagent/confirm_delete.html"
    )
    return render(request, template, context)
