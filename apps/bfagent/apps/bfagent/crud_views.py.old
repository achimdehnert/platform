"""
CRUD Views for BF Agent - Book Factory Agent Management System
Create, Read, Update, Delete operations for all models
"""

from django.contrib import messages
from django.core.paginator import Paginator
from django.http import HttpRequest, HttpResponse
from django.shortcuts import get_object_or_404, redirect, render
from django.views.decorators.http import require_http_methods

from .forms import AgentForm, BookChapterForm, BookProjectForm, BookTypeForm, CharacterForm, LlmForm
from .models import Agents, BookChapters, BookProjects, Characters, Llms
from .services.llm_client import LlmRequest, generate_text


# PROJECT CRUD VIEWS
def project_create(request):
    """Create a new book project"""
    if request.method == "POST":
        form = BookProjectForm(request.POST)
        if form.is_valid():
            project = form.save()
            messages.success(request, f'Project "{project.title}" created successfully!')
            if request.htmx:
                from django.core.paginator import Paginator

                projects_qs = BookProjects.objects.all().order_by("-created_at")
                paginator = Paginator(projects_qs, 12)
                page_obj = paginator.get_page(1)
                return render(request, "bfagent/partials/project_list.html", {"page_obj": page_obj})
            return redirect("bfagent:project-list")
        else:
            form.add_error(None, "Please correct the highlighted errors to save the Project.")
            template = (
                "bfagent/partials/project_form.html"
                if request.htmx
                else "bfagent/project_form.html"
            )
            response = render(request, template, {"form": form, "title": "Create New Project"})
            if request.htmx:
                response.status_code = 422
            return response
    else:
        form = BookProjectForm()

    context = {"form": form, "title": "Create New Project"}
    template = "bfagent/partials/project_form.html" if request.htmx else "bfagent/project_form.html"
    return render(request, template, context)


def project_edit(request, pk):
    """Edit an existing book project"""
    project = get_object_or_404(BookProjects, pk=pk)

    if request.method == "POST":
        form = BookProjectForm(request.POST, instance=project)
        if form.is_valid():
            project = form.save()
            messages.success(request, f'Project "{project.title}" updated successfully!')
            if request.htmx:
                from django.core.paginator import Paginator

                projects_qs = BookProjects.objects.all().order_by("-created_at")
                paginator = Paginator(projects_qs, 12)
                page_obj = paginator.get_page(1)
                return render(request, "bfagent/partials/project_list.html", {"page_obj": page_obj})
            return redirect("bfagent:project-list")
        else:
            form.add_error(None, "Please correct the highlighted errors to save the Project.")
            template = (
                "bfagent/partials/project_form.html"
                if request.htmx
                else "bfagent/project_form.html"
            )
            response = render(
                request,
                template,
                {"form": form, "project": project, "title": f"Edit {project.title}"},
            )
            if request.htmx:
                response.status_code = 422
            return response
    else:
        form = BookProjectForm(instance=project)

    context = {"form": form, "project": project, "title": f"Edit {project.title}"}
    template = "bfagent/partials/project_form.html" if request.htmx else "bfagent/project_form.html"
    return render(request, template, context)


def project_delete(request, pk):
    """Delete a book project"""
    project = get_object_or_404(BookProjects, pk=pk)

    if request.method == "POST":
        project_title = project.title
        project.delete()
        messages.success(request, f'Project "{project_title}" deleted successfully!')
        return redirect("bfagent:project-list")

    context = {"object": project, "object_type": "Project"}
    template = (
        "bfagent/partials/confirm_delete.html" if request.htmx else "bfagent/confirm_delete.html"
    )
    return render(request, template, context)


