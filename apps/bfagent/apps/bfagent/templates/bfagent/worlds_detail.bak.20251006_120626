{% extends 'base.html' %}
{% load static %}

{% block title %}Worlds Details{% endblock %}

{% block content %}
<div class="container">
    <div class="card shadow-sm">
        <div class="card-header bg-info text-white">
            <div class="d-flex justify-content-between align-items-center">
                <h3 class="mb-0">
                    <i class="bi bi-info-circle"></i> Worlds Details
                </h3>
                <a href="{% url 'bfagent:worlds_list' %}" class="btn btn-light btn-sm">
                    <i class="bi bi-arrow-left"></i> Back to List
                </a>
            </div>
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-8">
                    <dl class="row">
                        {% for field in worlds._meta.fields %}
                        <dt class="col-sm-4">{{ field.verbose_name|title }}:</dt>
                        <dd class="col-sm-8">{{ worlds|get_item:field.name|default:"—" }}</dd>
                        {% endfor %}
                    </dl>
                </div>
                <div class="col-md-4">
                    <div class="d-grid gap-2">
                        <a href="{% url 'bfagent:worlds_edit' worlds.pk %}"
                           class="btn btn-warning">
                            <i class="bi bi-pencil"></i> Edit
                        </a>
                        <form method="post" action="{% url 'bfagent:worlds_delete' worlds.pk %}">
                            {% csrf_token %}
                            <button type="submit"
                                    class="btn btn-danger w-100"
                                    onclick="return confirm('Are you sure you want to delete this Worlds?')">
                                <i class="bi bi-trash"></i> Delete
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
