<div class="alert alert-danger mt-2">
    <div class="d-flex justify-content-between align-items-start">
        <div>
            <h6 class="alert-heading">
                <i class="bi bi-exclamation-triangle"></i> {{ tool.name }} - Execution Failed
            </h6>
            <p class="mb-1">
                <strong>Error:</strong> {{ error }}
            </p>
            <p class="mb-1">
                <strong>Failed at:</strong> {{ executed_at|date:"M d, Y H:i:s" }}
            </p>
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
    <hr>
    <div class="mt-2">
        <h6>Troubleshooting:</h6>
        <ul class="mb-0">
            {% if tool.executable_path %}
                <li>
                    Check if script exists: <code>{{ tool.executable_path }}</code>
                </li>
            {% endif %}
            {% if tool.make_command %}
                <li>
                    Try running manually: <code>make {{ tool.make_command }}</code>
                </li>
            {% endif %}
            <li>Check tool dependencies and permissions</li>
            <li>Review system logs for more details</li>
        </ul>
    </div>
    <div class="mt-2">
        <small class="text-muted">Tool: {{ tool.description }} (v{{ tool.version }})</small>
    </div>
</div>
