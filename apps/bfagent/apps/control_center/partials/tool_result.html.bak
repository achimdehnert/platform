<div class="alert alert-success mt-2">
    <div class="d-flex justify-content-between align-items-start">
        <div>
            <h6 class="alert-heading">
                <i class="bi bi-check-circle"></i> {{ tool.name }} - Execution Complete
            </h6>
            <p class="mb-1">
                <strong>Status:</strong>
                {% if result.success %}
                    <span class="badge bg-success">Success</span>
                {% else %}
                    <span class="badge bg-warning">Completed with issues</span>
                {% endif %}
            </p>
            <p class="mb-1">
                <strong>Executed at:</strong> {{ executed_at|date:"M d, Y H:i:s" }}
            </p>
            {% if result.returncode is not None %}
                <p class="mb-1">
                    <strong>Return Code:</strong> {{ result.returncode }}
                </p>
            {% endif %}
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
    {% if result.stdout %}
        <hr>
        <div class="mt-2">
            <h6>Output:</h6>
            <pre class="bg-light p-2 rounded"
                 style="max-height: 200px;
                        overflow-y: auto;
                        font-size: 0.8rem">{{ result.stdout }}</pre>
        </div>
    {% endif %}
    {% if result.stderr %}
        <div class="mt-2">
            <h6 class="text-warning">Errors/Warnings:</h6>
            <pre class="bg-warning bg-opacity-10 p-2 rounded"
                 style="max-height: 200px;
                        overflow-y: auto;
                        font-size: 0.8rem">{{ result.stderr }}</pre>
        </div>
    {% endif %}
    <div class="mt-2">
        <small class="text-muted">Tool: {{ tool.description }} (v{{ tool.version }})</small>
    </div>
</div>
