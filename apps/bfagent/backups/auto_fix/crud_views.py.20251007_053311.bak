                    "form": form,
                    "character": None,
                    "title": "Create New Character",
                }
                return render(request, "bfagent/partials/character_form.html", context)
    else:
        form = CharacterForm()

    context = {
        "form": form,
        "character": None,
        "title": "Create New Character",
    }

    if request.htmx:
        return render(request, "bfagent/partials/character_form.html", context)

    return render(request, "bfagent/character_form.html", context)


