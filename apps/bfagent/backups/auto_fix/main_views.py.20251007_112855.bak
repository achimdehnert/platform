from django.contrib import messages
from django.contrib.auth.mixins import LoginRequiredMixin
from django.core.paginator import Paginator
from django.db.models import Q
from django.http import HttpResponse
from django.template.loader import render_to_string
from django.urls import reverse_lazy
from django.views.generic import CreateView, DeleteView, DetailView, ListView, UpdateView

from ..forms import LlmsForm
from ..models import Llms


class LlmsListView(LoginRequiredMixin, ListView):
    """List view for Llms"""

    model = Llms
    template_name = "bfagent/llms_list.html"
    context_object_name = "llms"
    paginate_by = 20

    def get_queryset(self):
        queryset = super().get_queryset()
        # Add any common annotations
        # queryset = queryset.annotate(
        #     days_since_created=Now() - F('created_at')
        # )

        # Search functionality
        search_query = self.request.GET.get("search")
        if search_query:
            # CUSTOM_CODE_START: search_fields
            # Customize search fields here
            queryset = queryset.filter(
                Q(name__icontains=search_query)
                # Add more search fields as needed
            )
            # CUSTOM_CODE_END:

        # CUSTOM_CODE_START: queryset_filters
        # Add custom filtering logic here
        # CUSTOM_CODE_END:

        # Ordering
        ordering = self.request.GET.get("ordering", "-created_at")
        queryset = queryset.order_by(ordering)

        return queryset

    def get_context_data(self, **kwargs):
        context = super().get_context_data(**kwargs)
        context["list_fields"] = []
        context["total_count"] = self.get_queryset().count()

        # CUSTOM_CODE_START: extra_context
        # Add custom context variables here
        # CUSTOM_CODE_END:

        return context


class LlmsDetailView(LoginRequiredMixin, DetailView):
    """Detail view for Llms"""

    model = Llms
    template_name = "bfagent/llms_detail.html"
    context_object_name = "llms"

    def get_queryset(self):
        queryset = super().get_queryset()
        # Add any common annotations
        # queryset = queryset.annotate(
        #     days_since_created=Now() - F('created_at')
        # )
        return queryset


class LlmsCreateView(LoginRequiredMixin, CreateView):
    """Create view for Llms"""

    model = Llms
    form_class = LlmsForm
    template_name = "bfagent/llms_form.html"
    success_url = reverse_lazy("bfagent:llms-list")

    def form_valid(self, form):
        # CUSTOM_CODE_START: form_valid_create
        # Add custom logic before saving
        # Example: form.instance.created_by = self.request.user
        # CUSTOM_CODE_END:

        response = super().form_valid(form)
        messages.success(self.request, f"Llms created successfully!")

        # HTMX handling
        if self.request.headers.get("HX-Request"):
            context = {
                "llmss": Llms.objects.all()[:20],
                "list_fields": [],
                "messages": messages.get_messages(self.request),
            }
            html = render_to_string(
                "bfagent/partials/llms_partial_list.html", context, request=self.request
            )
            return HttpResponse(html)
        return response

    def form_invalid(self, form):
        # HTMX error handling
        if self.request.headers.get("HX-Request"):
            response = super().form_invalid(form)
            response["HX-Retarget"] = "#modal-container"
            response["HX-Reswap"] = "innerHTML"
            return response
        return super().form_invalid(form)


class LlmsEditView(LoginRequiredMixin, UpdateView):
    """Edit view for Llms"""

    model = Llms
    form_class = LlmsForm
    template_name = "bfagent/llms_form.html"
    success_url = reverse_lazy("bfagent:llms-list")

    def get_queryset(self):
        queryset = super().get_queryset()
        # Add any common annotations
        # queryset = queryset.annotate(
        #     days_since_created=Now() - F('created_at')
        # )
        return queryset

    def form_valid(self, form):
        # CUSTOM_CODE_START: form_valid_edit
        # Add custom logic before saving
        # Example: form.instance.modified_by = self.request.user
        # CUSTOM_CODE_END:

        response = super().form_valid(form)
        messages.success(self.request, f"Llms updated successfully!")

        # HTMX handling
        if self.request.headers.get("HX-Request"):
            context = {
                "llmss": Llms.objects.all()[:20],
                "list_fields": [],
                "messages": messages.get_messages(self.request),
            }
            html = render_to_string(
                "bfagent/partials/llms_partial_list.html", context, request=self.request
            )
            return HttpResponse(html)
        return response


class LlmsDeleteView(LoginRequiredMixin, DeleteView):
    """Delete view for Llms"""

    model = Llms
    template_name = "bfagent/llms_confirm_delete.html"
    success_url = reverse_lazy("bfagent:llms-list")

    def delete(self, request, *args, **kwargs):
        # CUSTOM_CODE_START: delete_logic
        # Add custom deletion logic
        # CUSTOM_CODE_END:

        obj = self.get_object()
        messages.success(request, f'Llms "{obj}" deleted successfully!')

        if request.headers.get("HX-Request"):
            super().delete(request, *args, **kwargs)
            return HttpResponse(status=204)
        return super().delete(request, *args, **kwargs)


