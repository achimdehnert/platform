<!-- AUTO_GENERATED: PromptTemplate_DETAIL -->
{% extends "base.html" %}
{% load static %}

{% block title %}PromptTemplate Detail{% endblock %}

{% block content %}
<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1><i class="bi bi-eye"></i> PromptTemplate Detail</h1>
        <div>
            <a href="{% url 'bfagent:prompttemplate-list' %}" class="btn btn-secondary">
                <i class="bi bi-arrow-left"></i> Back to List
            </a>
            <a href="{% url 'bfagent:prompttemplate-update' object.pk %}" class="btn btn-primary">
                <i class="bi bi-pencil"></i> Edit
            </a>
        </div>
    </div>

    <div class="card shadow">
        <div class="card-body">
            <div class="row mb-3">
                <div class="col-md-3"><strong>Name:</strong></div>
                <div class="col-md-9">{{ object.name }}</div>
            </div>
            <div class="row mb-3">
                <div class="col-md-3"><strong>Agent:</strong></div>
                <div class="col-md-9">{{ object.agent }}</div>
            </div>
            <div class="row mb-3">
                <div class="col-md-3"><strong>Version:</strong></div>
                <div class="col-md-9">{{ object.version }}</div>
            </div>
            <div class="row mb-3">
                <div class="col-md-3"><strong>Avg Quality Score:</strong></div>
                <div class="col-md-9">{{ object.avg_quality_score }}</div>
            </div>
            <div class="row mb-3">
                <div class="col-md-3"><strong>Usage Count:</strong></div>
                <div class="col-md-9">{{ object.usage_count }}</div>
            </div>
        </div>
        <div class="card-footer">
            <a href="{% url 'bfagent:prompttemplate-delete' object.pk %}" class="btn btn-danger">
                <i class="bi bi-trash"></i> Delete
            </a>
        </div>
    </div>
</div>
{% endblock %}
