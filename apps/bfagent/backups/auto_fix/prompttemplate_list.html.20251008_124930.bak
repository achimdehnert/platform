<!-- AUTO_GENERATED: PromptTemplate_LIST -->
{% extends "base.html" %}
{% load static %}

{% block title %}Prompt Template List{% endblock %}

{% block content %}
<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1><i class="bi bi-list"></i> Prompt Template List</h1>
        <a href="{% url 'bfagent:prompttemplate-create' %}" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> Create Prompt Template
        </a>
    </div>

    <div class="card shadow">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead>
                        <tr>
                    <th>Name</th>
                    <th>Agent</th>
                    <th>Version</th>
                    <th>Avg Quality Score</th>
                    <th>Usage Count</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for item in page_obj %}
                        <tr>
                    <td>{{ item.name }}</td>
                    <td>{{ item.agent }}</td>
                    <td>{{ item.version }}</td>
                    <td>{{ item.avg_quality_score }}</td>
                    <td>{{ item.usage_count }}</td>
                            <td>
                                <div class="btn-group btn-group-sm">
                                    <a href="{% url 'bfagent:prompttemplate-detail' item.pk %}"
                                       class="btn btn-outline-primary" title="View">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    <a href="{% url 'bfagent:prompttemplate-update' item.pk %}"
                                       class="btn btn-outline-secondary" title="Edit">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <a href="{% url 'bfagent:prompttemplate-delete' item.pk %}"
                                       class="btn btn-outline-danger" title="Delete">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                        {% empty %}
                        <tr>
                            <td colspan="6" class="text-center text-muted">
                                No prompt templates found.
                                <a href="{% url 'bfagent:prompttemplate-create' %}">Create one now</a>
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>

            {% if is_paginated %}
            <nav aria-label="Page navigation">
                <ul class="pagination justify-content-center">
                    {% if page_obj.has_previous %}
                    <li class="page-item">
                        <a class="page-link" href="?page=1">First</a>
                    </li>
                    <li class="page-item">
                        <a class="page-link" href="?page={{ page_obj.previous_page_number }}">Previous</a>
                    </li>
                    {% endif %}

                    <li class="page-item active">
                        <span class="page-link">Page {{ page_obj.number }} of {{ page_obj.paginator.num_pages }}</span>
                    </li>

                    {% if page_obj.has_next %}
                    <li class="page-item">
                        <a class="page-link" href="?page={{ page_obj.next_page_number }}">Next</a>
                    </li>
                    <li class="page-item">
                        <a class="page-link" href="?page={{ page_obj.paginator.num_pages }}">Last</a>
                    </li>
                    {% endif %}
                </ul>
            </nav>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}
