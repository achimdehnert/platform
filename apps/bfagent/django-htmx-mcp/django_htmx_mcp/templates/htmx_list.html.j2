{# HTMX List Page Template #}
{% raw %}{% extends "base.html" %}
{% load static %}

{% block title %}{{ {% endraw %}{{ model_name }}{% raw %} }} List{% endblock %}

{% block content %}
<div class="container mx-auto px-4 py-8">
    <div class="flex justify-between items-center mb-6">
        <h1 class="text-2xl font-bold">{% endraw %}{{ model_name }}{% raw %} List</h1>
{% endraw %}
{% if with_create_button %}
{% raw %}
        <a href="{% url '{% endraw %}{{ app_name }}:{{ model_name|snake_case }}{% raw %}_create' %}"
           class="btn btn-primary"
           hx-get="{% url '{% endraw %}{{ app_name }}:{{ model_name|snake_case }}{% raw %}_create' %}"
           hx-target="#modal-container"
           hx-swap="innerHTML">
            + New {% endraw %}{{ model_name }}{% raw %}
        </a>
{% endraw %}
{% endif %}
{% raw %}
    </div>
{% endraw %}

{% if with_search %}
{% raw %}
    <!-- Search -->
    <div class="mb-4">
        <input type="text"
               name="q"
               placeholder="Search..."
               class="input input-bordered w-full max-w-xs"
               hx-get="{% url '{% endraw %}{{ app_name }}:{{ model_name|snake_case }}{% raw %}_list' %}"
               hx-trigger="keyup changed delay:300ms"
               hx-target="#{% endraw %}{{ model_name|snake_case }}{% raw %}-list"
               hx-swap="innerHTML">
    </div>
{% endraw %}
{% endif %}

{% raw %}
    <!-- List Container -->
    <div id="{% endraw %}{{ model_name|snake_case }}{% raw %}-list"
         hx-get="{% url '{% endraw %}{{ app_name }}:{{ model_name|snake_case }}{% raw %}_list' %}"
         hx-trigger="load, {% endraw %}{{ model_name|snake_case }}{% raw %}Changed from:body"
         hx-swap="innerHTML">
        {% include "{% endraw %}{{ app_name }}/partials/{{ model_name|snake_case }}{% raw %}_list_partial.html" %}
    </div>

    <!-- Modal Container -->
    <div id="modal-container"></div>
</div>
{% endblock %}
{% endraw %}
