# =============================================================================
# BF Agent - Development Environment Configuration
# =============================================================================
# Copy this file to .env and adjust values as needed
# NEVER commit .env to git!
# =============================================================================

# Django Settings
DJANGO_SETTINGS_MODULE=config.settings.development
DJANGO_SECRET_KEY=dev-secret-key-change-in-production-abc123xyz789
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# =============================================================================
# Database (PostgreSQL via Docker)
# =============================================================================
POSTGRES_DB=bfagent_dev
POSTGRES_USER=bfagent
POSTGRES_PASSWORD=bfagent_dev_2024
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# =============================================================================
# Redis (for caching & Celery)
# =============================================================================
REDIS_URL=redis://localhost:6379/0
REDIS_PORT=6379

# =============================================================================
# API Keys (Development - use test/sandbox keys)
# =============================================================================
OPENAI_API_KEY=sk-your-openai-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# =============================================================================
# Optional: pgAdmin (Web UI for PostgreSQL)
# =============================================================================
PGADMIN_EMAIL=admin@bfagent.local
PGADMIN_PASSWORD=admin
PGADMIN_PORT=5050

# =============================================================================
# Logging
# =============================================================================
LOG_LEVEL=DEBUG

# =============================================================================
# Feature Flags (Development)
# =============================================================================
ENABLE_DEBUG_TOOLBAR=True
ENABLE_SILK_PROFILER=False
