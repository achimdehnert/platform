{
  "_comment": "MCP Configuration for Sentry & Grafana",
  "_comment2": "Copy this configuration to your Claude Desktop config",
  "_comment3": "Location: %APPDATA%/Claude/claude_desktop_config.json (Windows)",
  "_comment4": "Or: ~/Library/Application Support/Claude/claude_desktop_config.json (Mac)",

  "mcpServers": {
    "sentry": {
      "command": "npx",
      "args": [
        "-y",
        "@getsentry/sentry-mcp",
        "--token",
        "YOUR_SENTRY_TOKEN",
        "--org",
        "YOUR_ORG_SLUG"
      ],
      "env": {
        "SENTRY_DSN": "YOUR_SENTRY_DSN"
      }
    },
    "grafana": {
      "command": "npx",
      "args": [
        "-y",
        "@grafana/mcp-grafana",
        "--url",
        "https://YOUR_ORG.grafana.net",
        "--token",
        "YOUR_GRAFANA_TOKEN"
      ]
    }
  }
}
