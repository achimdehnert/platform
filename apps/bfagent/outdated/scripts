class APIEndpointChecker:
    """
    Advanced API endpoint analysis and validation with performance optimizations
    """

    def __init__(
        self,
        app_name: str = "bfagent",
        include_admin: bool = False,
        profile_performance: bool = False,
    ):
        self.app_name = app_name
        self.include_admin = include_admin
        self.profile_performance = profile_performance
        self.console = Console() if RICH_AVAILABLE else None

        # Data storage
        self.models: Dict[str, Dict[str, Any]] = {}
        self.endpoints: List[EndpointInfo] = []
        self.coverage: Dict[str, ModelEndpointCoverage] = {}

        # Performance tracking
        self.performance_metrics: Dict[str, float] = {}

    def scan_models(self) -> None:
        """Scan all models in the app with performance tracking"""
        start_time = time.time()

        try:
            app_config = apps.get_app_config(self.app_name)
            all_models = list(app_config.get_models())

            if self.console and RICH_AVAILABLE:
                with Progress(
                    SpinnerColumn(),
                    TextColumn("[progress.description]{task.description}"),
                    BarColumn(),
                    console=self.console,
                ) as progress:
                    task = progress.add_task(
                        f"Scanning {len(all_models)} models...", total=len(all_models)
                    )

                    for model in all_models:
                        model_data = self._analyze_model(model)
                        self.models[model.__name__] = model_data
                        progress.advance(task)
            else:
                for model in all_models:
                    model_data = self._analyze_model(model)
                    self.models[model.__name__] = model_data

            if self.profile_performance:
                self.performance_metrics["model_scan_time"] = time.time() - start_time

            logger.info(f"Successfully scanned {len(self.models)} models")

        except Exception as e:
            logger.error(f"Error scanning models: {e}")
            raise

    def _analyze_model(self, model: type[models.Model]) -> Dict[str, Any]:
        """Analyze a single Django model"""
        meta = model._meta

        fields = []
        relationships = []

        for field in meta.get_fields():
            if hasattr(field, "name"):
                field_info = {
                    "name": field.name,
                    "type": field.__class__.__name__,
                    "required": not getattr(field, "blank", True),
                    "null": getattr(field, "null", True),
                    "max_length": getattr(field, "max_length", None),
                    "choices": bool(getattr(field, "choices", None)),
                    "help_text": getattr(field, "help_text", ""),
                }

                if isinstance(
                    field, (models.ForeignKey, models.ManyToManyField, models.OneToOneField)
                ):
                    relationships.append(
                        {
                            "field": field.name,
                            "type": field.__class__.__name__,
                            "related_model": field.related_model.__name__,
                            "on_delete": (
                                getattr(field, "on_delete", None).__name__
                                if hasattr(field, "on_delete")
                                else None
                            ),
                        }
                    )
                else:
                    fields.append(field_info)

        return {
            "name": model.__name__,
            "app": meta.app_label,
            "db_table": meta.db_table,
            "verbose_name": str(meta.verbose_name),
            "verbose_name_plural": str(meta.verbose_name_plural),
            "fields": fields,
            "relationships": relationships,
            "has_crud_config": hasattr(model, "CRUDConfig"),
            "expected_endpoints": self._get_expected_endpoints(model),
            "abstract": meta.abstract,
            "proxy": meta.proxy,
            "ordering": meta.ordering or [],
            "permissions": meta.permissions or [],
        }

    def _get_expected_endpoints(self, model: type[models.Model]) -> List[Dict[str, str]]:
        """Get expected REST endpoints for a model"""
        model_name = model.__name__.lower()

        # Smart pluralization with proper Django model handling
        model_name_plural = self._pluralize_model_name(model_name)

        # Override for specific BF Agent models
        model_plurals = {
            "bookprojects": "projects",
            "bookchapters": "chapters",
            "agentexecutions": "executions",
            "agentartifacts": "artifacts",
            "booktypes": "book-types",
        }

        if model_name in model_plurals:
            model_name_plural = model_plurals[model_name]

        endpoints = [
            {
                "method": "GET",
                "path": f"/api/{model_name_plural}/",
                "description": "List all items",
            },
            {
                "method": "POST",
                "path": f"/api/{model_name_plural}/",
                "description": "Create new item",
            },
            {
                "method": "GET",
                "path": f"/api/{model_name_plural}/{{id}}/",
                "description": "Get single item",
            },
            {
                "method": "PUT",
                "path": f"/api/{model_name_plural}/{{id}}/",
                "description": "Update item",
            },
            {
                "method": "PATCH",
                "path": f"/api/{model_name_plural}/{{id}}/",
                "description": "Partial update",
            },
            {
                "method": "DELETE",
                "path": f"/api/{model_name_plural}/{{id}}/",
                "description": "Delete item",
            },
        ]

        # Add custom actions if CRUDConfig exists
        if hasattr(model, "CRUDConfig"):
            crud_config = model.CRUDConfig
            if hasattr(crud_config, "custom_actions"):
                for action in crud_config.custom_actions:
                    endpoints.append(
                        {
                            "method": "POST",
                            "path": f"/api/{model_name_plural}/{{id}}/{action}/",
                            "description": f"Custom action: {action}",
                        }
                    )

        return endpoints

    def _pluralize_model_name(self, model_name: str) -> str:
        """Smart pluralization for model names"""
        # Handle compound words first
        if "project" in model_name:
            return model_name.replace("bookproject", "project")
        if "chapter" in model_name:
            return model_name.replace("bookchapter", "chapter")
        if "execution" in model_name:
            return model_name.replace("agentexecution", "execution")
        if "artifact" in model_name:
            return model_name.replace("agentartifact", "artifact")

        # Standard pluralization rules
        if model_name.endswith("s"):
            return model_name
        elif model_name.endswith("y"):
            return model_name[:-1] + "ies"
        elif model_name.endswith(("ch", "sh", "x", "z")):
            return model_name + "es"
        else:
            return model_name + "s"

    def scan_urls(self) -> None:
        """Scan all URL patterns with async detection"""
        start_time = time.time()

        try:
            resolver = get_resolver()
            self.endpoints = self._extract_urls(resolver.url_patterns)

            # Analyze API coverage
            self._analyze_api_coverage()

            if self.profile_performance:
                self.performance_metrics["url_scan_time"] = time.time() - start_time

            logger.info(f"Found {len(self.endpoints)} endpoints")

        except Exception as e:
            logger.error(f"Error scanning URLs: {e}")
            raise

    def _extract_urls(
        self, patterns: List[Union[URLResolver, URLPattern]], prefix: str = "", namespace: str = ""
    ) -> List[EndpointInfo]:
        """Recursively extract URL patterns with enhanced metadata"""
        endpoints = []

        for pattern in patterns:
            if isinstance(pattern, URLResolver):
                # Handle included URLs
                sub_prefix = prefix + str(pattern.pattern)
                sub_namespace = (
                    f"{namespace}:{pattern.namespace}" if pattern.namespace else namespace
                )

                if not self.include_admin and "admin" in str(pattern.pattern):
                    continue

                endpoints.extend(
                    self._extract_urls(pattern.url_patterns, sub_prefix, sub_namespace)
                )

            elif isinstance(pattern, URLPattern):
                # Handle individual URL patterns
                path = prefix + str(pattern.pattern)
                view_name = getattr(pattern, "name", "")

                endpoint_info = self._analyze_endpoint(pattern, path, namespace, view_name)
                if endpoint_info:
                    endpoints.append(endpoint_info)

        return endpoints

    def _analyze_endpoint(
        self, pattern: URLPattern, path: str, namespace: str, view_name: str
    ) -> Optional[EndpointInfo]:
        """Analyze a single endpoint with detailed metadata"""
        try:
            # Clean path
            clean_path = self._clean_path(path)

            # Get HTTP methods and view info
            methods, view_class, is_async = self._get_view_info(pattern)

            # Get docstring
            docstring = None
            if hasattr(pattern.callback, "__doc__"):
                docstring = pattern.callback.__doc__
            elif hasattr(pattern.callback, "view_class") and hasattr(
                pattern.callback.view_class, "__doc__"
            ):
                docstring = pattern.callback.view_class.__doc__

            # Extract parameters from path
            parameters = self._extract_path_parameters(clean_path)

            return EndpointInfo(
                path=clean_path,
                name=pattern.name or "",
                view_name=view_name,
                methods=[HTTPMethod(m) for m in methods],
                namespace=namespace,
                is_api=self._is_api_endpoint(clean_path),
                is_rest=self._is_rest_endpoint(clean_path),
                is_async=is_async,
                view_class=view_class,
                docstring=docstring,
                parameters=parameters,
            )

        except Exception as e:
            logger.warning(f"Error analyzing endpoint {path}: {e}")
            return None

    def _get_view_info(self, pattern: URLPattern) -> Tuple[List[str], Optional[str], bool]:
        """Get HTTP methods, view class name, and async status"""
        try:
            view = pattern.callback
            methods = ["GET"]  # Default
            view_class = None
            is_async = False

            # Check if it's an async view
            if asyncio.iscoroutinefunction(view):
                is_async = True

            if hasattr(view, "view_class"):
                # Class-based view
                view_cls = view.view_class
                view_class = f"{view_cls.__module__}.{view_cls.__name__}"

                # Get HTTP methods
                if hasattr(view_cls, "http_method_names"):
                    methods = [
                        m.upper()
                        for m in view_cls.http_method_names
                        if m not in ("options", "head")
                    ]
                else:
                    # Check for method handlers
                    available_methods = []
                    for method in ["get", "post", "put", "patch", "delete"]:
                        if hasattr(view_cls, method):
                            available_methods.append(method.upper())
                    if available_methods:
                        methods = available_methods

                # Check if any methods are async
                for method in ["get", "post", "put", "patch", "delete"]:
                    if hasattr(view_cls, method):
                        method_func = getattr(view_cls, method)
                        if asyncio.iscoroutinefunction(method_func):
                            is_async = True
                            break

            elif hasattr(view, "__name__"):
                # Function-based view
                view_class = f"{view.__module__}.{view.__name__}"
                # For function views, we can't easily determine methods
                methods = ["GET", "POST"]  # Common assumption

            return methods, view_class, is_async

        except Exception:
            return ["GET"], None, False

    def _clean_path(self, path: str) -> str:
        """Clean and normalize URL path"""
        import re

        path = str(path)

        # Handle Django URL patterns safely
        try:
            # Remove start/end anchors
            path = re.sub(r"^\^", "", path)
            path = re.sub(r"\$$", "", path)

            # Convert Django named groups to simple placeholders
            # Pattern: (?P<name>pattern) -> {name}
            path = re.sub(r"\(\?P<(\w+)>[^)]+\)", r"{\1}", path)

            # Handle simple patterns like <int:pk>
            path = re.sub(r"<int:(\w+)>", r"{\1}", path)
            path = re.sub(r"<str:(\w+)>", r"{\1}", path)
            path = re.sub(r"<slug:(\w+)>", r"{\1}", path)

            # Remove remaining backslashes
            path = path.replace("\\", "")

            # Ensure leading slash
            if not path.startswith("/"):
                path = "/" + path

            # Clean double slashes
            while "//" in path:
                path = path.replace("//", "/")

        except Exception as e:
            logger.warning(f"Error cleaning path '{path}': {e}")
            # Fallback: basic cleaning
            path = path.replace("^", "").replace("$", "").replace("\\", "")
            if not path.startswith("/"):
                path = "/" + path

        return path

    def _extract_path_parameters(self, path: str) -> List[Dict[str, Any]]:
        """Extract parameters from URL path"""
        import re

        parameters = []

        # Find all parameters in curly braces
        param_pattern = r"\{(\w+)\}"
        for match in re.finditer(param_pattern, path):
            param_name = match.group(1)

            # Determine type based on common patterns
            param_type = "string"
            if param_name in ("id", "pk"):
                param_type = "integer"
            elif param_name.endswith("_id"):
                param_type = "integer"

            parameters.append(
                {"name": param_name, "in": "path", "required": True, "schema": {"type": param_type}}
            )

        return parameters

    @lru_cache(maxsize=256)
    def _is_api_endpoint(self, path: str) -> bool:
        """Check if endpoint is an API endpoint"""
        api_patterns = ("/api/", "/rest/", "/v1/", "/v2/", "/v3/", "/graphql/", "/ws/")
        return any(pattern in path.lower() for pattern in api_patterns)

    @lru_cache(maxsize=256)
    def _is_rest_endpoint(self, path: str) -> bool:
        """Check if endpoint follows REST conventions"""
        if not self._is_api_endpoint(path):
            return False

        import re

        rest_patterns = [
            r"/api/[\w-]+/?$",  # Collection endpoint
            r"/api/[\w-]+/\{[\w]+\}/?$",  # Item endpoint
            r"/api/v\d+/[\w-]+/?$",  # Versioned collection
            r"/api/v\d+/[\w-]+/\{[\w]+\}/?$",  # Versioned item
        ]

        return any(re.match(pattern, path) for pattern in rest_patterns)

    def _analyze_api_coverage(self) -> None:
        """Analyze API coverage for each model"""
        for model_name, model_data in self.models.items():
            coverage = ModelEndpointCoverage(
                model_name=model_name,
                expected_endpoints=model_data["expected_endpoints"],
                found_endpoints=[],
                missing_endpoints=[],
            )

            # Find matching endpoints
            model_name_lower = model_name.lower()
            for endpoint in self.endpoints:
                if self._endpoint_matches_model(endpoint, model_name_lower):
                    coverage.found_endpoints.append(endpoint)

            # Find missing endpoints
            for expected in model_data["expected_endpoints"]:
                found = False
                for actual in coverage.found_endpoints:
                    if expected["method"] in [
                        m.value for m in actual.methods
                    ] and self._paths_match(expected["path"], actual.path):
                        found = True
                        break

                if not found:
                    coverage.missing_endpoints.append(expected)

            coverage.calculate_coverage()
            self.coverage[model_name] = coverage

    def _endpoint_matches_model(self, endpoint: EndpointInfo, model_name: str) -> bool:
        """Check if endpoint matches a model"""
        path = endpoint.path.lower()
        return model_name in path or f"{model_name}s" in path

    def _paths_match(self, expected: str, actual: str) -> bool:
        """Check if expected and actual paths match"""
        import re

        # Normalize paths
        expected = expected.lower().replace("{id}", r"{\w+}")
        actual = actual.lower()

        # Convert to regex
        expected_regex = expected.replace("/", r"\/")
        expected_regex = re.sub(r"\{\\w\+\}", r"\{[^}]+\}", expected_regex)

        return bool(re.match(f"^{expected_regex}$", actual))

    def generate_openapi_spec(
        self,
        title: Optional[str] = None,
        version: str = "1.0.0",
        servers: Optional[List[Dict[str, str]]] = None,
    ) -> Dict[str, Any]:
        """Generate OpenAPI 3.1 specification"""
        if not self.models:
            self.scan_models()
        if not self.endpoints:
            self.scan_urls()

        spec = {
            "openapi": "3.1.0",
            "info": {
                "title": title or f"{self.app_name.title()} API",
                "version": version,
                "description": f"Auto-generated API specification for {self.app_name}",
                "contact": {"name": "API Support", "email": "api@example.com"},
                "license": {"name": "MIT", "url": "https://opensource.org/licenses/MIT"},
                "x-generated": {
                    "timestamp": datetime.now().isoformat(),
                    "generator": "BF Agent API Checker v3.0",
                },
            },
            "servers": servers
            or [
                {"url": "http://127.0.0.1:8000", "description": "Development server"},
                {"url": "https://api.example.com", "description": "Production server"},
            ],
            "paths": {},
            "components": {
                "schemas": {},
                "securitySchemes": {
                    "bearerAuth": {"type": "http", "scheme": "bearer", "bearerFormat": "JWT"},
                    "cookieAuth": {"type": "apiKey", "in": "cookie", "name": "sessionid"},
                },
                "responses": {
                    "BadRequest": {
                        "description": "Bad request",
                        "content": {
                            "application/json": {"schema": {"$re": "#/components/schemas/Error"}}
                        },
                    },
                    "NotFound": {
                        "description": "Resource not found",
                        "content": {
                            "application/json": {"schema": {"$re": "#/components/schemas/Error"}}
                        },
                    },
                },
            },
            "tags": [],
            "security": [{"bearerAuth": []}, {"cookieAuth": []}],
        }

        # Add error schema
        spec["components"]["schemas"]["Error"] = {
            "type": "object",
            "properties": {
                "error": {"type": "string"},
                "message": {"type": "string"},
                "details": {"type": "object"},
            },
            "required": ["error", "message"],
        }

        # Generate schemas for models
        for model_name, model_data in self.models.items():
            if not model_data["abstract"]:
                schema = self._generate_model_schema(model_name, model_data)
                spec["components"]["schemas"][model_name] = schema

                # Add tag
                spec["tags"].append(
                    {
                        "name": model_name,
                        "description": f"Operations related to {model_data['verbose_name_plural']}",
                    }
                )

        # Generate paths for API endpoints
        api_endpoints = [e for e in self.endpoints if e.is_api]
        for endpoint in api_endpoints:
            self._add_endpoint_to_spec(endpoint, spec)

        return spec

    def _generate_model_schema(self, model_name: str, model_data: Dict[str, Any]) -> Dict[str, Any]:
        """Generate OpenAPI schema for a model"""
        schema = {
            "type": "object",
            "title": model_name,
            "description": f"Schema for {model_data['verbose_name']}",
            "properties": {
                "id": {"type": "integer", "readOnly": True, "description": "Unique identifier"}
            },
            "required": [],
        }

        # Add fields
        for field in model_data["fields"]:
            field_schema = self._get_field_schema(field)
            schema["properties"][field["name"]] = field_schema

            if field["required"] and not field["null"]:
                schema["required"].append(field["name"])

        # Add relationships
        for rel in model_data["relationships"]:
            if rel["type"] == "ForeignKey":
                schema["properties"][f"{rel['field']}_id"] = {
                    "type": "integer",
                    "description": f"ID of related {rel['related_model']}",
                }
            elif rel["type"] == "ManyToManyField":
                schema["properties"][f"{rel['field']}_ids"] = {
                    "type": "array",
                    "items": {"type": "integer"},
                    "description": f"IDs of related {rel['related_model']}s",
                }

        # Add timestamps
        schema["properties"]["created_at"] = {
            "type": "string",
            "format": "date-time",
            "readOnly": True,
        }
        schema["properties"]["updated_at"] = {
            "type": "string",
            "format": "date-time",
            "readOnly": True,
        }

        return schema

    def _get_field_schema(self, field: Dict[str, Any]) -> Dict[str, Any]:
        """Convert Django field to OpenAPI schema"""
        type_mapping = {
            "CharField": ("string", None),
            "TextField": ("string", None),
            "SlugField": ("string", None),
            "EmailField": ("string", "email"),
            "URLField": ("string", "uri"),
            "UUIDField": ("string", "uuid"),
            "IntegerField": ("integer", "int32"),
            "BigIntegerField": ("integer", "int64"),
            "SmallIntegerField": ("integer", "int32"),
            "PositiveIntegerField": ("integer", "int32"),
            "FloatField": ("number", "float"),
            "DecimalField": ("number", "double"),
            "BooleanField": ("boolean", None),
            "DateField": ("string", "date"),
            "DateTimeField": ("string", "date-time"),
            "TimeField": ("string", "time"),
            "DurationField": ("string", "duration"),
            "FileField": ("string", "binary"),
            "ImageField": ("string", "binary"),
            "JSONField": ("object", None),
        }

        openapi_type, openapi_format = type_mapping.get(field["type"], ("string", None))

        schema = {"type": openapi_type, "description": field.get("help_text", "")}

        if openapi_format:
            schema["format"] = openapi_format

        if field.get("max_length"):
            schema["maxLength"] = field["max_length"]

        if field.get("choices"):
            schema["enum"] = []  # Would need actual choices values

        if field.get("null"):
            schema["nullable"] = True

        return schema

    def _add_endpoint_to_spec(self, endpoint: EndpointInfo, spec: Dict[str, Any]) -> None:
        """Add endpoint to OpenAPI spec"""
        path = endpoint.path

        # Replace Django-style parameters with OpenAPI style
        import re

        path = re.sub(r"\{(\w+)\}", r"{\1}", path)

        if path not in spec["paths"]:
            spec["paths"][path] = {}

        # Determine which model this endpoint belongs to
        tag = None
        for model_name in self.models:
            if self._endpoint_matches_model(endpoint, model_name.lower()):
                tag = model_name
                break

        # Add operations for each method
        for method in endpoint.methods:
            method_lower = method.value.lower()

            operation = {
                "summary": f"{method.value} {path}",
                "description": endpoint.docstring
                or f"Auto-generated endpoint for {endpoint.full_name}",
                "operationId": f"{endpoint.operation_id}_{method_lower}",
                "tags": [tag] if tag else [],
                "parameters": endpoint.parameters.copy(),
                "responses": {
                    "200": {
                        "description": "Successful response",
                        "content": {"application/json": {"schema": {"type": "object"}}},
                    },
                    "400": {"$re": "#/components/responses/BadRequest"},
                    "404": {"$re": "#/components/responses/NotFound"},
                },
            }

            # Add request body for methods that typically have one
            if method.value in ("POST", "PUT", "PATCH"):
                operation["requestBody"] = {
                    "required": True,
                    "content": {"application/json": {"schema": {"type": "object"}}},
                }

            # Mark async endpoints
            if endpoint.is_async:
                operation["x-async"] = True

            spec["paths"][path][method_lower] = operation

    def validate_openapi_spec(self, spec: Dict[str, Any]) -> Tuple[bool, List[str]]:
        """Validate OpenAPI specification"""
        if not OPENAPI_VALIDATOR_AVAILABLE:
            logger.warning("openapi-spec-validator not installed, skipping validation")
            return True, []

        errors = []
        try:
            validate_spec(spec)
            return True, []
        except Exception as e:
            errors.append(str(e))
            return False, errors

    def generate_report(self) -> APIAnalysisReport:
        """Generate comprehensive analysis report"""
        if not self.models:
            self.scan_models()
        if not self.endpoints:
            self.scan_urls()

        # Calculate metrics
        api_endpoints = [e for e in self.endpoints if e.is_api]
        rest_endpoints = [e for e in self.endpoints if e.is_rest]
        async_endpoints = [e for e in self.endpoints if e.is_async]

        report = APIAnalysisReport(
            generated_at=datetime.now(),
            app_name=self.app_name,
            total_models=len(self.models),
            total_endpoints=len(self.endpoints),
            api_endpoints=len(api_endpoints),
            rest_endpoints=len(rest_endpoints),
            async_endpoints=len(async_endpoints),
            models=self.models,
            endpoints=self.endpoints,
            coverage=self.coverage,
            performance_metrics=self.performance_metrics,
        )

        # Add warnings
        for model_name, coverage in self.coverage.items():
            if coverage.coverage_percent < 50:
                report.warnings.append(
                    f"Low API coverage for {model_name}: {coverage.coverage_percent:.1f}%"
                )

        # Check for async views (modern Django feature)
        if async_endpoints:
            report.warnings.append(
                f"Found {len(async_endpoints)} async endpoints - ensure proper async support"
            )

        return report

    def export_report(self, output_file: Union[str, Path], format: str = "json") -> None:
        """Export analysis report"""
        report = self.generate_report()
        output_path = Path(output_file)
        output_path.parent.mkdir(parents=True, exist_ok=True)

        if format.lower() == "json":
            with open(output_path, "w", encoding="utf-8") as f:
                # Convert dataclasses to dict
                report_dict = asdict(report)
                # Convert EndpointInfo objects
                report_dict["endpoints"] = [asdict(e) for e in report.endpoints]
                # Convert HTTPMethod enums
                for endpoint in report_dict["endpoints"]:
                    endpoint["methods"] = [m.value for m in endpoint["methods"]]

                json.dump(report_dict, f, indent=2, default=str)

        elif format.lower() == "yaml":
            with open(output_path, "w", encoding="utf-8") as f:
                report_dict = asdict(report)
                report_dict["endpoints"] = [asdict(e) for e in report.endpoints]
                for endpoint in report_dict["endpoints"]:
                    endpoint["methods"] = [m.value for m in endpoint["methods"]]

                yaml.dump(report_dict, f, default_flow_style=False, allow_unicode=True)

        logger.info(f"Report exported to {output_path}")

        if self.console:
            self.console.print(f"[green]✓ Report exported to {output_path}[/green]")

    def print_analysis(self) -> None:
        """Print comprehensive analysis to console"""
        report = self.generate_report()

        if self.console and RICH_AVAILABLE:
            # Summary panel
            summary_table = Table(title="📊 API Analysis Summary")
            summary_table.add_column("Metric", style="cyan")
            summary_table.add_column("Value", style="green")

            summary_data = [
                ("Total Models", str(report.total_models)),
                ("Total Endpoints", str(report.total_endpoints)),
                ("API Endpoints", str(report.api_endpoints)),
                ("REST Endpoints", str(report.rest_endpoints)),
                ("Async Endpoints", str(report.async_endpoints)),
                (
                    "Models with CRUDConfig",
                    str(sum(1 for m in self.models.values() if m["has_crud_config"])),
                ),
            ]

            for metric, value in summary_data:
                summary_table.add_row(metric, value)

            self.console.print(summary_table)

            # Coverage table
            coverage_table = Table(title="🎯 API Coverage by Model")
            coverage_table.add_column("Model", style="cyan")
            coverage_table.add_column("Expected", justify="center")
            coverage_table.add_column("Found", justify="center")
            coverage_table.add_column("Missing", justify="center")
            coverage_table.add_column("Coverage", justify="center")

            for model_name, coverage in self.coverage.items():
                if coverage.expected_endpoints:  # Only show models with expected endpoints
                    coverage_color = (
                        "green"
                        if coverage.coverage_percent >= 80
                        else "yellow" if coverage.coverage_percent >= 50 else "red"
                    )

                    coverage_table.add_row(
                        model_name,
                        str(len(coverage.expected_endpoints)),
                        str(len(coverage.found_endpoints)),
                        str(len(coverage.missing_endpoints)),
                        f"[{coverage_color}]{coverage.coverage_percent:.1f}%[/{coverage_color}]",
                    )

            self.console.print(coverage_table)

            # Missing endpoints
            if any(c.missing_endpoints for c in self.coverage.values()):
                self.console.print("\n[red]🚨 Missing Endpoints:[/red]")
                for model_name, coverage in self.coverage.items():
                    if coverage.missing_endpoints:
                        self.console.print(f"\n[yellow]{model_name}:[/yellow]")
                        for missing in coverage.missing_endpoints:
                            self.console.print(
                                f"  • [red]{missing['method']}[/red] {missing['path']} - {missing['description']}"
                            )

            # Performance metrics
            if self.performance_metrics:
                self.console.print("\n[blue]⚡ Performance Metrics:[/blue]")
                for metric, value in self.performance_metrics.items():
                    self.console.print(f"  • {metric}: {value:.3f}s")

            # Warnings
            if report.warnings:
                self.console.print("\n[yellow]⚠️  Warnings:[/yellow]")
                for warning in report.warnings:
                    self.console.print(f"  • {warning}")

        else:
            # Plain text output
            print("\n📊 API Analysis Summary:")
            print(f"Total Models: {report.total_models}")
            print(f"Total Endpoints: {report.total_endpoints}")
            print(f"API Endpoints: {report.api_endpoints}")
            print(f"REST Endpoints: {report.rest_endpoints}")
            print(f"Async Endpoints: {report.async_endpoints}")

            print("\n🎯 API Coverage by Model:")
            for model_name, coverage in self.coverage.items():
                if coverage.expected_endpoints:
                    print(
                        f"{model_name}: {coverage.coverage_percent:.1f}% ({len(coverage.found_endpoints)}/{len(coverage.expected_endpoints)})"
                    )

            if any(c.missing_endpoints for c in self.coverage.values()):
                print("\n🚨 Missing Endpoints:")
                for model_name, coverage in self.coverage.items():
                    if coverage.missing_endpoints:
                        print(f"\n{model_name}:")
                        for missing in coverage.missing_endpoints:
                            print(
                                f"  {missing['method']} {missing['path']} - {missing['description']}"
                            )


def main():
    """Enhanced CLI with more options"""
    import argparse

    parser = argparse.ArgumentParser(
        description="Advanced API Endpoint Checker for Django",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
Examples:
  %(prog)s check --app myapp
  %(prog)s report --app myapp --output report.json
  %(prog)s openapi --app myapp --output openapi.yaml
  %(prog)s validate --app myapp --spec openapi.yaml
        """,
    )

    parser.add_argument(
        "command", choices=["check", "report", "openapi", "validate"], help="Command to execute"
    )
    parser.add_argument("--app", default="bfagent", help="Django app name (default: bfagent)")
    parser.add_argument("--output", help="Output file path")
    parser.add_argument(
        "--format", choices=["json", "yaml"], default="yaml", help="Output format (default: yaml)"
    )
    parser.add_argument("--include-admin", action="store_true", help="Include admin endpoints")
    parser.add_argument("--profile", action="store_true", help="Profile performance")
    parser.add_argument("--spec", help="OpenAPI spec file to validate")
    parser.add_argument("--title", help="API title for OpenAPI spec")
    parser.add_argument("--version", default="1.0.0", help="API version for OpenAPI spec")

    args = parser.parse_args()

    # Initialize checker
    checker = APIEndpointChecker(
        app_name=args.app, include_admin=args.include_admin, profile_performance=args.profile
    )

    try:
        if args.command == "check":
            checker.print_analysis()

        elif args.command == "report":
            if args.output:
                checker.export_report(args.output, args.format)
            else:
                checker.print_analysis()

        elif args.command == "openapi":
            spec = checker.generate_openapi_spec(title=args.title, version=args.version)

            # Validate spec
            is_valid, errors = checker.validate_openapi_spec(spec)

            if args.output:
                output_path = Path(args.output)
                output_path.parent.mkdir(parents=True, exist_ok=True)

                if args.format == "json":
                    with open(output_path, "w", encoding="utf-8") as f:
                        json.dump(spec, f, indent=2)
                else:
                    with open(output_path, "w", encoding="utf-8") as f:
                        yaml.dump(spec, f, default_flow_style=False, allow_unicode=True)

                if checker.console:
                    checker.console.print(f"[green]✓ OpenAPI spec saved to {output_path}[/green]")
                    if not is_valid:
                        checker.console.print(
                            f"[yellow]⚠️  Spec validation errors: {errors}[/yellow]"
                        )
                else:
                    print(f"✓ OpenAPI spec saved to {output_path}")
                    if not is_valid:
                        print(f"⚠️  Spec validation errors: {errors}")
            else:
                if args.format == "json":
                    print(json.dumps(spec, indent=2))
                else:
                    print(yaml.dump(spec, default_flow_style=False, allow_unicode=True))

        elif args.command == "validate":
            if args.spec:
                # Validate external spec
                spec_dict, base_uri = read_from_filename(args.spec)
                is_valid, errors = checker.validate_openapi_spec(spec_dict)

                if is_valid:
                    if checker.console:
                        checker.console.print("[green]✓ OpenAPI spec is valid![/green]")
                    else:
                        print("✓ OpenAPI spec is valid!")
                else:
                    if checker.console:
                        checker.console.print("[red]✗ OpenAPI spec validation errors:[/red]")
                        for error in errors:
                            checker.console.print(f"  • {error}")
                    else:
                        print("✗ OpenAPI spec validation errors:")
                        for error in errors:
                            print(f"  • {error}")
            else:
                # Generate and validate
                spec = checker.generate_openapi_spec()
                is_valid, errors = checker.validate_openapi_spec(spec)

                if is_valid:
                    if checker.console:
                        checker.console.print("[green]✓ Generated OpenAPI spec is valid![/green]")
                    else:
                        print("✓ Generated OpenAPI spec is valid!")
                else:
                    if checker.console:
                        checker.console.print("[red]✗ Validation errors in generated spec:[/red]")
                        for error in errors:
                            checker.console.print(f"  • {error}")
                    else:
                        print("✗ Validation errors in generated spec:")
                        for error in errors:
                            print(f"  • {error}")

    except Exception as e:
        logger.error(f"Error: {e}")
        if checker.console:
            checker.console.print(f"[red]✗ Error: {e}[/red]")
        else:
            print(f"✗ Error: {e}")
        sys.exit(1)


if __name__ == "__main__":
    main()
