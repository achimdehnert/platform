# Travel Beat - Caddy Configuration
# Add this to the main Caddyfile on Hetzner

travel-beat.iil.pet {
    encode gzip
    
    # Serve static files
    handle_path /static/* {
        root * /srv/travel-beat/static
        file_server
    }
    
    # Serve media files
    handle_path /media/* {
        root * /srv/travel-beat/media
        file_server
    }
    
    # All other requests go to Django
    reverse_proxy travel-beat-web:8000
}
