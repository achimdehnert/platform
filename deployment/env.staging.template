# Staging Environment Template (ADR-063)
# Copy to /opt/<app>-staging/.env.staging and fill in values.
# Port-Offset: Prod-Port + 100 (see ADR-063 port table)
#
# DO NOT commit real values — this is a template only.

# Django
SECRET_KEY=CHANGE-ME-STAGING
DEBUG=False
DJANGO_SETTINGS_MODULE=config.settings.production
DJANGO_ALLOWED_HOSTS=staging.<app-domain>
CSRF_TRUSTED_ORIGINS=https://staging.<app-domain>

# Database (separate staging DB — never share with prod!)
DATABASE_URL=postgres://staging_user:staging_pass@localhost:5432/<app>_staging

# Redis (can share instance, use different DB index)
REDIS_URL=redis://localhost:6379/1

# Email (always use console backend in staging)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# Port (see ADR-063 — Prod-Port + 100)
# bfagent:    8180  | dev-hub:   8181 | travel-beat: 8182
# weltenhub:  8185  | trading:   8188 | risk-hub:    8190
# cad-hub:    8194  | pptx-hub:  8195 | coach-hub:   8107
# wedding-hub: 8196
PORT=<staging-port>
