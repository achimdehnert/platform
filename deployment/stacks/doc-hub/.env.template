# ═══════════════════════════════════════════════════════════════════════════════
# doc-hub — Environment Variables (ADR-144)
# ═══════════════════════════════════════════════════════════════════════════════
# Copy to .env and fill in values. NEVER commit .env to Git.
# Generate secrets: python3 -c "import secrets; print(secrets.token_hex(32))"
# ═══════════════════════════════════════════════════════════════════════════════

# PostgreSQL
DOCHUB_DB_USER=paperless
DOCHUB_DB_PASS=CHANGE_ME_STRONG_PASSWORD

# Redis
DOCHUB_REDIS_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Paperless-ngx
DOCHUB_SECRET_KEY=CHANGE_ME_STRONG_SECRET_KEY

# Admin (only used on first start — remove after setup)
DOCHUB_ADMIN_USER=admin
DOCHUB_ADMIN_PASS=CHANGE_ME_ADMIN_PASSWORD

# OIDC (Phase 2 — after ADR-142 deploy)
# DOCHUB_OIDC_CLIENT_ID=
# DOCHUB_OIDC_SECRET=
# PAPERLESS_SOCIALACCOUNT_PROVIDERS=... (see ADR-144 Section 3.6)
