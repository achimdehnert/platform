# ═══════════════════════════════════════════════════════════════════════════════
# outline — Environment Variables (ADR-143)
# ═══════════════════════════════════════════════════════════════════════════════
# Copy to .env and fill in values. NEVER commit .env to Git.
# Generate secrets: python3 -c "import secrets; print(secrets.token_hex(32))"
# ═══════════════════════════════════════════════════════════════════════════════

# PostgreSQL
OUTLINE_DB_USER=outline
OUTLINE_DB_PASS=CHANGE_ME_STRONG_PASSWORD

# Redis
OUTLINE_REDIS_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Outline
OUTLINE_SECRET_KEY=CHANGE_ME_STRONG_SECRET_KEY
OUTLINE_UTILS_SECRET=CHANGE_ME_STRONG_UTILS_SECRET

# OIDC via authentik (ADR-142) — app-slug: outline
OUTLINE_OIDC_CLIENT_ID=CHANGE_ME_FROM_AUTHENTIK
OUTLINE_OIDC_CLIENT_SECRET=CHANGE_ME_FROM_AUTHENTIK
