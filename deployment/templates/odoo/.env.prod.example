# =============================================================================
# .env.prod (Odoo) — EXAMPLE (never commit actual secrets!)
# =============================================================================

APP_NAME=reporting
GHCR_OWNER=achimdehnert
GHCR_REPO=reporting-ui

# Release tag — injected by deploy-remote.sh
IMAGE_TAG=latest

# Database
POSTGRES_DB=reporting
POSTGRES_USER=reporting
POSTGRES_PASSWORD=CHANGE_ME

# Odoo module upgrade list (comma-separated)
ODOO_UPGRADE_MODULES=reporting_core

# Odoo runtime tuning
ODOO_WORKERS=2
ODOO_LIMIT_TIME_CPU=60
ODOO_LIMIT_TIME_REAL=120

# Nginx
NGINX_PORT=8080
