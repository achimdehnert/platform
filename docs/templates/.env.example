# IIL Platform — .env.example (Golden Path)
# Kopiere nach .env.prod (niemals committen!) und fülle echte Werte ein
# Referenz: ADR-022 (Secrets via env_file), ADR-045 (decouple.config())

# ── Django ────────────────────────────────────────────────────────────────────
SECRET_KEY=changeme-generate-with-python-secrets-token-hex-32
DEBUG=False
ALLOWED_HOSTS=REPO_NAME.iil.pet,localhost

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=REPO_NAME
POSTGRES_USER=REPO_NAME_user
POSTGRES_PASSWORD=changeme-strong-password
DATABASE_URL=postgresql://REPO_NAME_user:PASSWORT@db:5432/REPO_NAME

# ── Redis (optional — nur wenn Celery/Cache) ─────────────────────────────────
# REDIS_URL=redis://redis:6379/0

# ── E-Mail ────────────────────────────────────────────────────────────────────
EMAIL_HOST=mail.iil.pet
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=noreply@iil.pet
EMAIL_HOST_PASSWORD=changeme

# ── iil-Packages (nur wenn LLM benötigt) ─────────────────────────────────────
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=...

# ── App-spezifisch ────────────────────────────────────────────────────────────
# Eigene Variablen hier ergänzen — immer via decouple.config() lesen
