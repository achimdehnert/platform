# =============================================================================
# Weltenhub Environment Configuration
# =============================================================================
# Copy to .env.prod and fill in actual values
# NEVER commit .env.prod to git!
# =============================================================================

# -----------------------------------------------------------------------------
# Django Core
# -----------------------------------------------------------------------------
DJANGO_SETTINGS_MODULE=config.settings.production
SECRET_KEY=your-secret-key-here-minimum-50-characters-long
DEBUG=false
ALLOWED_HOSTS=weltenhub.iil.pet,localhost

# -----------------------------------------------------------------------------
# Database (External PostgreSQL 16)
# -----------------------------------------------------------------------------
DATABASE_URL=postgres://weltenhub:password@postgres-host:5432/weltenhub_db
DB_NAME=weltenhub_db
DB_USER=weltenhub
DB_PASSWORD=your-database-password
DB_HOST=postgres-host
DB_PORT=5432

# Optional: pgbouncer
# DATABASE_URL=postgres://weltenhub:password@pgbouncer-host:6432/weltenhub_db

# -----------------------------------------------------------------------------
# Redis (Cache & Celery Broker)
# -----------------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
CSRF_TRUSTED_ORIGINS=https://weltenhub.iil.pet
SECURE_SSL_REDIRECT=true
SESSION_COOKIE_SECURE=true
CSRF_COOKIE_SECURE=true

# -----------------------------------------------------------------------------
# Logging & Monitoring
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
SENTRY_DSN=

# -----------------------------------------------------------------------------
# Docker Image
# -----------------------------------------------------------------------------
IMAGE_TAG=latest
IMAGE_REPO=ghcr.io/achimdehnert/weltenhub

# -----------------------------------------------------------------------------
# Deployment
# -----------------------------------------------------------------------------
DEPLOY_HOST=88.198.191.108
DEPLOY_USER=root
DEPLOY_PATH=/opt/weltenhub
